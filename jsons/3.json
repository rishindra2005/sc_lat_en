n\":null,\"indent\":0,\"type\":\"info\"},\"content\":[{\"type\":\"text\",\"text\":\"Lists all sources cited in the article.\"}]}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null,\"indent\":0,\"type\":\"info\"}}]}",
